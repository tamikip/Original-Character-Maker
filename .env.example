PORT=3001
NODE_ENV=development
CORS_ORIGIN=*
MAX_UPLOAD_SIZE_BYTES=10485760
MIN_IMAGE_WIDTH=256
MIN_IMAGE_HEIGHT=256
IMAGE_GEN_CONCURRENCY=2
REMBG_CONCURRENCY=1

# 工作流模式: mock | live
PIPELINE_MODE=mock

# Provider 设置
BG_REMOVAL_PROVIDER=rembg
EXPRESSION_PROVIDER=mock
CG_PROVIDER=mock

# rembg 配置（本地 Python 环境）
# REMBG_PYTHON_PATH=/usr/bin/python3
REMBG_SCRIPT_PATH=./server/scripts/rembg_remove.py
REMBG_MODEL=isnet-anime
REMBG_TIMEOUT_MS=180000
REMBG_MIN_COVERAGE_RATIO=0.01

# Plato API（图像生成）
PLATO_API_KEY=
PLATO_BASE_URL=https://api.bltcy.ai/v1
PLATO_MODEL=gemini-3.1-flash-image-preview
PLATO_TIMEOUT_MS=120000

# Banana2 API（备用）
BANANA2_API_KEY=
BANANA2_BASE_URL=https://api.apiyi.com
BANANA2_MODEL=gemini-3.1-flash-image-preview

# 目录配置
UPLOAD_DIR=./tmp/uploads
WORKFLOW_STATE_DIR=./tmp/workflows
OUTPUT_DIR=./tmp/outputs
